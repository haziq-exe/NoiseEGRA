# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# Used by the LLM-judge scoring scripts (scripts/score_stories_gpt52.py and
# scripts/extract_parts_vendi.py), which load it via python-dotenv.

# Azure OpenAI (LLM judge) — all three are required; scripts will not run without them.
AZURE_KEY=
AZURE_ENDPOINT=https://<your-resource>.cognitiveservices.azure.com/
AZURE_DEPLOYMENT=gpt-4o
AZURE_API_VERSION=2024-12-01-preview

# Optional: override default experiment_results/ directory for all scripts
# EGRA_RESULTS_DIR=experiment_results

# Stories sent per judge request (default 10)
STORY_BATCH_SIZE=10

# Optional tokens used only by the experiment notebook (Kaggle):
# prefer Kaggle Secrets / environment variables over hardcoding.
# GITHUB_TOKEN=
# HF_TOKEN=
